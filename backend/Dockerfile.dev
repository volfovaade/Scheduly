FROM mcr.microsoft.com/dotnet/sdk:8.0
WORKDIR /app

# Copy csproj and restore dependencies
COPY backend/backend.csproj backend/
COPY backend.Tests/backend.Tests.csproj backend.Tests/
COPY backend/backend.sln backend/

RUN dotnet restore backend/backend.sln

# Copy source code
COPY backend/ backend/
COPY backend.Tests/ backend.Tests/

# Install dotnet watch tool (already included in SDK)
EXPOSE 80

# Use dotnet watch for hot reload
WORKDIR /app/backend
ENTRYPOINT ["dotnet", "watch", "run", "--urls", "http://0.0.0.0:80"]